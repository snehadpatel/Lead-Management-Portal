# MintLeads Environment Configuration
# Copy this file to .env and fill in your actual values

# Flask API Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# Streamlit Dashboard Configuration
STREAMLIT_PORT=8501

# Redis Configuration (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=mintleads

# External API Endpoints
AMFI_NAV_URL=https://www.amfiindia.com/spages/NAVAll.txt
NSE_MARKET_STATUS_URL=https://www.nseindia.com/api/marketStatus
NSE_HISTORICAL_URL=https://www.nseindia.com/api/historical/cm/equity

# RSS Feeds for Sentiment Analysis
MONEYCONTROL_RSS=https://www.moneycontrol.com/rss/MCtopnews.xml
ECONOMIC_TIMES_RSS=https://economictimes.indiatimes.com/markets/rssfeeds/1977021501.cms

# Dataset Paths (adjust based on your data location)
DATASETS_BASE=/Users/snehapatel/Library/CloudStorage/GoogleDrive-sneha.dipan.dec2005@gmail.com/My Drive/BigData/datasets
LEADS_DATA_PATH=/Users/snehapatel/Library/CloudStorage/GoogleDrive-sneha.dipan.dec2005@gmail.com/My Drive/BigData/datasets/structured/leads/lead_scoring/Lead Scoring.csv
INVESTOR_BEHAVIOR_PATH=/Users/snehapatel/Library/CloudStorage/GoogleDrive-sneha.dipan.dec2005@gmail.com/My Drive/BigData/datasets/models/ml_features/investor_profiles_scaled.csv
NAV_HISTORY_DIR=/Users/snehapatel/Library/CloudStorage/GoogleDrive-sneha.dipan.dec2005@gmail.com/My Drive/BigData/datasets/structured/mutual_funds/nav_history
AMFI_SCHEME_LIST_PATH=/Users/snehapatel/Library/CloudStorage/GoogleDrive-sneha.dipan.dec2005@gmail.com/My Drive/BigData/datasets/structured/mutual_funds/amfi_scheme_list.csv
NEWS_STREAM_PATH=/Users/snehapatel/Library/CloudStorage/GoogleDrive-sneha.dipan.dec2005@gmail.com/My Drive/BigData/datasets/velocity/live_news_stream.csv
NSE_PULSE_PATH=/Users/snehapatel/Library/CloudStorage/GoogleDrive-sneha.dipan.dec2005@gmail.com/My Drive/BigData/datasets/velocity/nse_market_pulse.csv

# Model Training Configuration
RANDOM_STATE=42
TEST_SIZE=0.2
CV_FOLDS=5

# LSTM Configuration
LSTM_WINDOW_SIZE=60
LSTM_EPOCHS=100
LSTM_BATCH_SIZE=32
LSTM_HIDDEN_SIZE=128
LSTM_DROPOUT=0.2

# Lead Scoring Thresholds
HOT_LEAD_THRESHOLD=0.85
WARM_LEAD_THRESHOLD=0.65

# Cache TTL (seconds)
CACHE_TTL=300

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Anthropic API Key (for call script generation)
# ANTHROPIC_API_KEY=your_api_key_here
