# Lume AI — Environment Configuration Template
# Copy this file to .env and update values

# ═══════════════════════════════════════════════════════════════════════════════
# PATHS (Adjust to your system)
# ═══════════════════════════════════════════════════════════════════════════════

# Base project directory
LUME_PROJECT_ROOT=/Users/snehapatel/Library/CloudStorage/GoogleDrive-sneha.dipan.dec2005@gmail.com/My Drive/BigData

# Dataset directory
LUME_DATA_ROOT=/Users/snehapatel/Library/CloudStorage/GoogleDrive-sneha.dipan.dec2005@gmail.com/My Drive/BigData/datasets

# Artifacts directory (models, cleaned data)
LUME_ARTIFACTS=/Users/snehapatel/Library/CloudStorage/GoogleDrive-sneha.dipan.dec2005@gmail.com/My Drive/BigData/artifacts

# MintLeads specific paths
DATASETS_BASE=/Users/snehapatel/Library/CloudStorage/GoogleDrive-sneha.dipan.dec2005@gmail.com/My Drive/BigData/datasets
LEADS_DATA_PATH=/Users/snehapatel/Library/CloudStorage/GoogleDrive-sneha.dipan.dec2005@gmail.com/My Drive/BigData/datasets/structured/leads/lead_scoring/Lead Scoring.csv
INVESTOR_BEHAVIOR_PATH=/Users/snehapatel/Library/CloudStorage/GoogleDrive-sneha.dipan.dec2005@gmail.com/My Drive/BigData/datasets/structured/leads/mf_investor_behavior/MF_Behavior.xlsx
NAV_HISTORY_DIR=/Users/snehapatel/Library/CloudStorage/GoogleDrive-sneha.dipan.dec2005@gmail.com/My Drive/BigData/datasets/structured/mutual_funds/nav_history

# ═══════════════════════════════════════════════════════════════════════════════
# SPARK CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Driver memory (adjust based on your system)
LUME_SPARK_DRIVER_MEMORY=8g

# Number of shuffle partitions
LUME_SPARK_SHUFFLE_PARTITIONS=200

# ═══════════════════════════════════════════════════════════════════════════════
# API CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Flask/FastAPI host and port
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
FLASK_DEBUG=false

# Dashboard port
STREAMLIT_PORT=8501

# ═══════════════════════════════════════════════════════════════════════════════
# REDIS CONFIGURATION (Optional - for caching)
# ═══════════════════════════════════════════════════════════════════════════════

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ═══════════════════════════════════════════════════════════════════════════════
# MLFLOW CONFIGURATION (Optional - for experiment tracking)
# ═══════════════════════════════════════════════════════════════════════════════

MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=mintleads

# ═══════════════════════════════════════════════════════════════════════════════
# BI TOOLS INTEGRATION
# ═══════════════════════════════════════════════════════════════════════════════

# Tableau Public embed URL (get from Tableau Public Share → Embed Code)
LUME_TABLEAU_EMBED_URL=https://public.tableau.com/views/YourWorkbook/Sheet1?:showVizHome=no&:embed=y

# Power BI embed URL (if using Power BI)
LUME_POWERBI_EMBED_URL=

# ═══════════════════════════════════════════════════════════════════════════════
# EXTERNAL API ENDPOINTS
# ═══════════════════════════════════════════════════════════════════════════════

# AMFI NAV Data
AMFI_NAV_URL=https://www.amfiindia.com/spages/NAVAll.txt

# NSE Market Status
NSE_MARKET_STATUS_URL=https://www.nseindia.com/api/marketStatus
NSE_HISTORICAL_URL=https://www.nseindia.com/api/historical/cm/equity

# RSS Feeds
MONEYCONTROL_RSS=https://www.moneycontrol.com/rss/MCtopnews.xml
ECONOMIC_TIMES_RSS=https://economictimes.indiatimes.com/markets/rssfeeds/1977021501.cms

# ═══════════════════════════════════════════════════════════════════════════════
# MODEL TRAINING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Random seed for reproducibility
RANDOM_STATE=42

# Train/test split ratio
TEST_SIZE=0.2

# Cross-validation folds
CV_FOLDS=5

# LSTM Configuration
LSTM_WINDOW_SIZE=60
LSTM_EPOCHS=100
LSTM_BATCH_SIZE=32
LSTM_HIDDEN_SIZE=128
LSTM_DROPOUT=0.2

# Lead Scoring Thresholds
HOT_LEAD_THRESHOLD=0.85
WARM_LEAD_THRESHOLD=0.65

# ═══════════════════════════════════════════════════════════════════════════════
# CACHE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Cache TTL in seconds
CACHE_TTL=300

# ═══════════════════════════════════════════════════════════════════════════════
# LOGGING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ═══════════════════════════════════════════════════════════════════════════════
# GOOGLE COLAB SPECIFIC (when running in Colab)
# ═══════════════════════════════════════════════════════════════════════════════

# Google Drive mount point in Colab
COLAB_DRIVE_MOUNT=/content/drive/MyDrive

# ═══════════════════════════════════════════════════════════════════════════════
# DEVELOPMENT SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Enable debug mode (true/false)
DEBUG=false

# Enable verbose logging
VERBOSE=false
